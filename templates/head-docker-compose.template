# ============================================================
# Server 1 (Head Node) — Ray Head + vLLM + Ollama + Nginx
# ============================================================
# 기동 순서: Server 2 (Worker) 먼저 → Server 1 (Head) 나중
# ============================================================

x-common-env-file: &common_env_file
  env_file:
    - env.proxy

x-common-locale-env: &common_locale_env
  LANG: C.UTF-8
  LC_ALL: C.UTF-8
  LANGUAGE: C.UTF-8

x-common-service: &common_service
  restart: unless-stopped
  <<: *common_env_file

services:
  # --------------------------------------------------------
  # vLLM — Ray Head + Model Serving
  # --------------------------------------------------------
  # network_mode: host 필수 (Ray 멀티노드 통신)
  # bridge 네트워크 대신 호스트 네트워크 직접 사용
  # --------------------------------------------------------
  vllm-gpu-all:
    <<: *common_service
    image: vllm/vllm-openai:latest
    container_name: vllm-gpu-all
    network_mode: host
    ipc: host
    shm_size: "{{SHM_SIZE}}"
    privileged: true        # NCCL 최적화를 위해 권장

    volumes:
      - ${SSL_CERT_FILE}:${SSL_CERT_FILE}:ro
      - ~/.cache/huggingface:/root/.cache/huggingface
      - ./data:/data

    environment:
      <<: *common_locale_env
      # --- GPU ---
      NVIDIA_VISIBLE_DEVICES: all
      CUDA_VISIBLE_DEVICES: "{{CUDA_VISIBLE_DEVICES}}"
      # --- NCCL ---
      NCCL_SOCKET_IFNAME: "${NIC_NAME:-eth0}"
      GLOO_SOCKET_IFNAME: "${NIC_NAME:-eth0}"
      NCCL_IB_DISABLE: "${NCCL_IB_DISABLE:-1}"
      NCCL_P2P_DISABLE: "0"
      NCCL_DEBUG: "WARN"
      NCCL_SOCKET_NTHREADS: "4"
      NCCL_NSOCKS_PERTHREAD: "4"
      NCCL_BUFFSIZE: "8388608"
      # --- vLLM ---
      VLLM_HOST_IP: "${HEAD_IP}"
      HF_TOKEN: "${HF_TOKEN}"
      VLLM_API_KEY: "${VLLM_API_KEY}"
      OMP_NUM_THREADS: "1"

    entrypoint: /bin/bash
    command: >
      -c "
        echo '[1/3] Starting Ray head node...'
        ray start --head --port=6379 --dashboard-host=0.0.0.0

        echo '[2/3] Waiting for {{TOTAL_GPU_COUNT}} GPUs across cluster...'
        MAX_WAIT=600
        ELAPSED=0
        while [ $$ELAPSED -lt $$MAX_WAIT ]; do
          GPU_COUNT=$$(ray status 2>/dev/null | grep -oP '\\d+\\.0 GPU' | head -1 | grep -oP '\\d+' || echo 0)
          echo \"  GPUs detected: $${GPU_COUNT}/{{TOTAL_GPU_COUNT}}  (elapsed: $${ELAPSED}s)\"
          if [ \"$$GPU_COUNT\" -ge {{TOTAL_GPU_COUNT}} ]; then
            break
          fi
          sleep 10
          ELAPSED=$$((ELAPSED + 10))
        done

        if [ \"$$GPU_COUNT\" -lt {{TOTAL_GPU_COUNT}} ]; then
          echo 'ERROR: Timed out waiting for {{TOTAL_GPU_COUNT}} GPUs. Check worker node.'
          ray status
          exit 1
        fi

        echo '[3/3] Starting vLLM server...'
        python -m vllm.entrypoints.openai.api_server \
          --host 0.0.0.0 \
          --port 8000 \
          --model {{MODEL_ID}} \
          --served-model-name {{SERVED_MODEL_NAME}} \
          --dtype bfloat16 \
          --tensor-parallel-size {{TENSOR_PARALLEL_SIZE}} \
          --pipeline-parallel-size {{PIPELINE_PARALLEL_SIZE}} \
          --distributed-executor-backend ray \
          --gpu-memory-utilization {{GPU_MEMORY_UTILIZATION}} \
          --max-model-len {{MAX_MODEL_LEN}} \
          --trust-remote-code
      "

    deploy:
      resources:
        reservations:
          devices:
            - driver: nvidia
              count: all
              capabilities: [gpu]

    healthcheck:
      test: ["CMD-SHELL", "curl -fsS http://localhost:8000/v1/models >/dev/null || exit 1"]
      interval: 30s
      timeout: 10s
      retries: 5
      start_period: 600s    # 모델 로딩 시간 고려하여 확대

  # --------------------------------------------------------
  # Ollama CPU
  # --------------------------------------------------------
  # host 네트워크: 11434 포트 직접 노출
  # --------------------------------------------------------
  ollama-cpu:
    <<: *common_service
    image: ollama/ollama:latest
    container_name: ollama-cpu
    network_mode: host

    volumes:
      - ${SSL_CERT_FILE}:${SSL_CERT_FILE}:ro
      - ollama-cpu-data:/root/.ollama

    environment:
      <<: *common_locale_env
      OLLAMA_HOST: "0.0.0.0:11434"
      OLLAMA_CONTEXT_LENGTH: "32768"
      OLLAMA_NUM_PARALLEL: "2"
      OLLAMA_KEEP_ALIVE: "120m"
      OLLAMA_MAX_LOADED_MODELS: "1"

  # --------------------------------------------------------
  # Nginx — Reverse Proxy / Router
  # --------------------------------------------------------
  # host 네트워크: upstream이 127.0.0.1로 변경됨
  # 기존 포트 매핑 → 직접 listen 포트로 대체
  # --------------------------------------------------------
  nginx:
    <<: *common_service
    image: nginx:latest
    container_name: nginx-lb
    network_mode: host

    depends_on:
      - vllm-gpu-all
      - ollama-cpu

    volumes:
      - ${SSL_CERT_FILE}:${SSL_CERT_FILE}:ro
      - ./nginx.conf:/etc/nginx/nginx.conf:ro

volumes:
  ollama-cpu-data:
